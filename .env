# UBEC Protocol - Environment Configuration
# ==========================================
#
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
#
# Never commit .env to version control - it may contain secrets!

# ========================================================================
# APPLICATION SETTINGS
# ========================================================================

# Environment: development, staging, or production
APP_ENV=development

# Host to bind application (0.0.0.0 for all interfaces, 127.0.0.1 for localhost)
APP_HOST=0.0.0.0

# Port to run application on
APP_PORT=8001

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================================================
# BACKEND API CONFIGURATION
# ========================================================================

# URL of the UBEC Protocol backend API service
# This is the main backend that provides all the data
BACKEND_API_URL=http://92.205.230.245:8000

# API key for backend authentication (leave empty if not required)
BACKEND_API_KEY=

# Backend API request timeout in seconds
BACKEND_TIMEOUT=30

# ========================================================================
# CACHE SETTINGS
# ========================================================================

# Cache TTL for API responses in seconds
CACHE_TTL_SECONDS=30

# Maximum number of cached items
CACHE_MAX_SIZE=1000

# ========================================================================
# CORS SETTINGS
# ========================================================================

# Allowed origins for CORS (comma-separated)
# Include your frontend URLs here
ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001,http://92.205.230.245:8001,https://ubec.network,https://www.ubec.network,https://mapservice.ubec.network

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,92.205.230.245,ubec.network,www.ubec.network,mapservice.ubec.network

# ========================================================================
# FEATURE FLAGS
# ========================================================================

# Enable API documentation at /api/docs and /api/redoc
ENABLE_API_DOCS=true

# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Enable WebSocket support for real-time updates
ENABLE_WEBSOCKETS=false

# ========================================================================
# RATE LIMITING
# ========================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60

# ========================================================================
# SECURITY
# ========================================================================

# Secret key for session management and CSRF protection
# IMPORTANT: Change this to a random value in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-value-in-production

# ========================================================================
# DATABASE (Optional - if using database directly)
# ========================================================================

# PostgreSQL connection URL (optional, backend API is used by default)
DATABASE_URL=postgresql://ubec:ubec@localhost:5432/ubec_protocol

# ========================================================================
# STELLAR NETWORK (Optional - for reference)
# ========================================================================

# Stellar network: public or testnet
STELLAR_NETWORK=public

# Stellar Horizon API URL
STELLAR_HORIZON_URL=https://horizon.stellar.org


# ========================================================================
# Email Service
# ========================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@ubec.network
SMTP_FROM_NAME=UBEC Protocol

# ========================================================================
# NOTES
# ========================================================================

# For Production:
# ---------------
# 1. Set APP_ENV=production
# 2. Generate strong SECRET_KEY (32+ characters)
# 3. Use HTTPS URLs for BACKEND_API_URL
# 4. Set ENABLE_API_DOCS=false
# 5. Restrict ALLOWED_ORIGINS to your domain only
# 6. Use environment variables instead of .env file if possible

# For Development:
# ----------------
# 1. Set APP_ENV=development
# 2. Keep ENABLE_API_DOCS=true
# 3. Use APP_HOST=127.0.0.1 for localhost only access

# For Remote Backend:
# -------------------
# If your backend is on a different server (like 92.205.230.245):
# 1. Set BACKEND_API_URL to the full URL including protocol and port
# 2. Ensure firewall allows connections to backend port
# 3. Add backend server to ALLOWED_ORIGINS if frontend makes direct calls
