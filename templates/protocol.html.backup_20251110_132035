{% extends "base.html" %}

{% block title %}Protocol Overview - UBEC Protocol Network{% endblock %}

{% block extra_css %}
<style>
    /* ====================================================================
       PROTOCOL PAGE STYLES
       Character Encoding: UTF-8 (Emojis: 🌬️💧🌍🔥🌐⚡💰🌱🔒🛠️♻️🏗️🔄🎯🔐)
       Ensure base.html includes: <meta charset="UTF-8">
       All styles inline following about.html pattern
       ==================================================================== */
    
    /* Protocol Hero - Ubuntu Earth-Tone Gradient */
    .protocol-hero {
        background: linear-gradient(135deg, #8BC34A 0%, #87CEEB 100%);
        padding: 4rem 0;
        text-align: center;
    }
    
    .protocol-hero h1,
    .protocol-hero .hero-title {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: #2c3e50;
    }
    
    .protocol-hero .lead {
        font-size: 1.25rem;
        color: #2c3e50;
    }
    
    /* Protocol Sections */
    .protocol-section {
        margin: var(--spacing-xxl) 0;
        padding: var(--spacing-xxl) 0;
    }
    
    .protocol-section:not(:last-child) {
        border-bottom: 1px solid var(--border-light);
    }
    
    /* Token Details Grid */
    .token-details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--spacing-xl);
        margin-top: var(--spacing-xl);
    }
    
    /* Element-specific borders */
    .token-detail-card.token-air { 
        border-left: 6px solid var(--element-air);
    }
    
    .token-detail-card.token-water { 
        border-left: 6px solid var(--element-water);
    }
    
    .token-detail-card.token-earth { 
        border-left: 6px solid var(--element-earth);
    }
    
    .token-detail-card.token-fire { 
        border-left: 6px solid var(--element-fire);
    }
    
    .token-header {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-lg);
        padding-bottom: var(--spacing-md);
        border-bottom: 2px solid var(--border-light);
    }
    
    .token-symbol {
        font-size: var(--font-size-5xl);
        line-height: 1;
    }
    
    .token-header h3 {
        font-size: var(--font-size-2xl);
        margin: 0;
    }
    
    .token-specs {
        margin-top: var(--spacing-md);
    }
    
    .token-specs dt {
        font-weight: 600;
        color: var(--text-primary);
        margin-top: var(--spacing-sm);
        font-size: var(--font-size-sm);
    }
    
    .token-specs dd {
        margin-left: 0;
        margin-bottom: var(--spacing-sm);
        color: var(--text-secondary);
        font-size: var(--font-size-sm);
    }
    
    .address {
        font-family: var(--font-monospace);
        font-size: var(--font-size-xs);
        word-break: break-all;
        color: var(--text-secondary);
        background: var(--background-alt);
        padding: var(--spacing-xs) var(--spacing-sm);
        border-radius: var(--radius-sm);
        display: inline-block;
    }
    
    .badge.status-ready {
        background: #e3f2fd;
        color: var(--info);
    }
    
    /* Holonic Dimensions */
    .holonic-dimensions {
        display: grid;
        gap: var(--spacing-lg);
        margin-top: var(--spacing-xl);
    }
    
    .dimension-card h4 {
        font-size: var(--font-size-xl);
        margin-bottom: var(--spacing-md);
    }
    
    .score-bar {
        height: 32px;
        background: var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin: var(--spacing-md) 0;
    }
    
    .score-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--element-earth), var(--success));
        transition: width var(--transition-slow);
    }
    
    .score-value {
        display: block;
        text-align: right;
        font-weight: 600;
        color: var(--success);
        font-size: var(--font-size-xl);
        margin-top: var(--spacing-xs);
    }
    
    .dimension-description {
        margin-top: var(--spacing-md);
        color: var(--text-secondary);
        font-size: var(--font-size-sm);
        line-height: 1.6;
    }
    
    .no-data-message {
        text-align: center;
        padding: var(--spacing-xxl);
        background: var(--background-alt);
        border-radius: var(--radius-lg);
        color: var(--text-secondary);
    }
    
    /* Stellar Integration */
    .integration-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--spacing-xl);
        margin-top: var(--spacing-xl);
    }
    
    .detail-box {
        text-align: center;
    }
    
    .detail-icon {
        font-size: var(--font-size-5xl);
        margin-bottom: var(--spacing-md);
        line-height: 1;
    }
    
    .detail-box h4 {
        font-size: var(--font-size-lg);
        margin-bottom: var(--spacing-sm);
    }
    
    .detail-box p {
        line-height: 1.6;
        margin: 0;
    }
    
    .detail-note {
        color: var(--text-light);
        font-size: var(--font-size-xs);
        margin-top: var(--spacing-xs);
    }
    
    .stellar-benefits {
        margin-top: var(--spacing-xxl);
        padding: var(--spacing-xxl);
        background: var(--background-alt);
        border-radius: var(--radius-lg);
    }
    
    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--spacing-xl);
        margin-top: var(--spacing-xl);
    }
    
    .benefit-item {
        text-align: center;
    }
    
    .benefit-icon {
        font-size: var(--font-size-5xl);
        display: block;
        margin-bottom: var(--spacing-md);
    }
    
    .benefit-item h5 {
        font-size: var(--font-size-lg);
        margin-bottom: var(--spacing-sm);
        color: var(--text-primary);
    }
    
    .benefit-item p {
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }
    
    /* Architecture Components */
    .architecture-components {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--spacing-xl);
        margin-top: var(--spacing-xl);
    }
    
    .component-card {
        padding: var(--spacing-xl);
    }
    
    .component-card h4 {
        font-size: var(--font-size-xl);
        margin-bottom: var(--spacing-lg);
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }
    
    .component-card ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .component-card li {
        padding: var(--spacing-sm) 0;
        color: var(--text-secondary);
        line-height: 1.6;
        border-bottom: 1px solid var(--border-light);
    }
    
    .component-card li:last-child {
        border-bottom: none;
    }
    
    .component-card strong {
        color: var(--text-primary);
        font-weight: 600;
    }
    
    /* Protocol CTA */
    .protocol-cta {
        margin-top: var(--spacing-xxxl);
        padding: var(--spacing-xxl);
        text-align: center;
        background: var(--background-alt);
        border-radius: var(--radius-lg);
    }
    
    .protocol-cta .section-title {
        margin-bottom: var(--spacing-md);
    }
    
    .protocol-cta .section-description {
        margin-bottom: var(--spacing-xl);
    }
    
    .protocol-cta .cta-buttons {
        display: flex;
        gap: var(--spacing-md);
        justify-content: center;
        flex-wrap: wrap;
    }
    
    /* Section Elements */
    .section-title {
        font-size: var(--font-size-4xl);
        margin-bottom: var(--spacing-md);
        color: var(--text-primary);
    }
    
    .section-description {
        font-size: var(--font-size-lg);
        color: var(--text-secondary);
        line-height: 1.8;
        max-width: 900px;
    }
    
    /* Responsive Design */
    @media (max-width: 768px) {
        .protocol-hero h1,
        .protocol-hero .hero-title {
            font-size: 2rem;
        }
        
        .token-details-grid,
        .integration-details,
        .benefits-grid,
        .architecture-components {
            grid-template-columns: 1fr;
        }
        
        .protocol-cta .cta-buttons {
            flex-direction: column;
        }
    }
</style>
{% endblock %}

{% block content %}
<!-- Protocol Hero -->
<section class="protocol-hero">
    <div class="container">
        <h1 class="hero-title">UBEC Protocol Overview</h1>
        <p class="lead">
            A comprehensive guide to the four-element token architecture<br>
            and Ubuntu-aligned economic principles
        </p>
    </div>
</section>

<!-- Main Protocol Content -->
<section class="section">
    <div class="container">
        <!-- Token Ecosystem Section -->
        <div class="protocol-section">
            <h2 class="section-title">Four-Element Token Ecosystem</h2>
            <p class="section-description">
                The UBEC Protocol implements a sophisticated token architecture based on the four classical elements,
                each representing a fundamental aspect of economic cooperation according to Ubuntu philosophy.
            </p>
            
            <div class="token-details-grid">
                {% if tokens %}
                    {% for token in tokens %}
                    <div class="card token-detail-card token-{{ token.get('element', 'Unknown')|lower }}">
                        <div class="token-header">
                            <span class="token-symbol">{{ token.get('element_symbol', 'Unknown') }}</span>
                            <h3>{{ token.token_code }} - {{ token.get('element', 'Unknown') }}</h3>
                        </div>
                        <dl class="token-specs">
                            <dt>Ubuntu Principle:</dt>
                            <dd>{{ token.get('ubuntu_principle', '') }}</dd>
                            
                            <dt>Issuer Address:</dt>
                            <dd class="address">{{ token.issuer[:8] }}...{{ token.issuer[-8:] }}</dd>
                            
                            <dt>Total Supply:</dt>
                            <dd>{{ "{:,.0f}".format(token.get("total_supply", 0)) }} tokens</dd>
                            
                            <dt>Current Holders:</dt>
                            <dd>{{ token.holders_count }} accounts</dd>
                            
                            <dt>Status:</dt>
                            <dd><span class="badge status-{{ token.status }}">{{ token.status|capitalize }}</span></dd>
                        </dl>
                    </div>
                    {% endfor %}
                {% else %}
                    <!-- Fallback if tokens not loaded - with proper UTF-8 emojis -->
                    <div class="card token-detail-card token-air">
                        <div class="token-header">
                            <span class="token-symbol">🌬️</span>
                            <h3>UBEC - Air</h3>
                        </div>
                        <dl class="token-specs">
                            <dt>Ubuntu Principle:</dt>
                            <dd>Diversity</dd>
                            <dt>Status:</dt>
                            <dd><span class="badge status-live">Live</span></dd>
                        </dl>
                    </div>
                    
                    <div class="card token-detail-card token-water">
                        <div class="token-header">
                            <span class="token-symbol">💧</span>
                            <h3>UBECrc - Water</h3>
                        </div>
                        <dl class="token-specs">
                            <dt>Ubuntu Principle:</dt>
                            <dd>Reciprocity</dd>
                            <dt>Status:</dt>
                            <dd><span class="badge status-ready">Ready</span></dd>
                        </dl>
                    </div>
                    
                    <div class="card token-detail-card token-earth">
                        <div class="token-header">
                            <span class="token-symbol">🌍</span>
                            <h3>UBECgpi - Earth</h3>
                        </div>
                        <dl class="token-specs">
                            <dt>Ubuntu Principle:</dt>
                            <dd>Mutualism</dd>
                            <dt>Status:</dt>
                            <dd><span class="badge status-ready">Ready</span></dd>
                        </dl>
                    </div>
                    
                    <div class="card token-detail-card token-fire">
                        <div class="token-header">
                            <span class="token-symbol">🔥</span>
                            <h3>UBECtt - Fire</h3>
                        </div>
                        <dl class="token-specs">
                            <dt>Ubuntu Principle:</dt>
                            <dd>Regeneration</dd>
                            <dt>Status:</dt>
                            <dd><span class="badge status-ready">Ready</span></dd>
                        </dl>
                    </div>
                {% endif %}
            </div>
        </div>
        
        <!-- Holonic Evaluation Framework -->
        <div class="protocol-section">
            <h2 class="section-title">Holonic Evaluation Framework</h2>
            <p class="section-description">
                Network participants are evaluated across five dimensions of Ubuntu alignment,
                creating a holonic (nested whole) assessment of their contribution to the commons.
            </p>
            
            {% if holonic_scores %}
            <div class="holonic-dimensions">
                <div class="card dimension-card">
                    <h4>Autonomy Integration</h4>
                    <div class="score-bar">
                        <div class="score-fill" style="width: {{ (holonic_scores.get("autonomy_integration", 0) * 100)|round }}%"></div>
                    </div>
                    <span class="score-value">{{ (holonic_scores.get("autonomy_integration", 0) * 100)|round }}%</span>
                    <p class="dimension-description">
                        Measures the balance between individual autonomy and collective integration,
                        reflecting how participants maintain their unique identity while contributing to the whole.
                    </p>
                </div>
                
                <div class="card dimension-card">
                    <h4>Ubuntu Alignment</h4>
                    <div class="score-bar">
                        <div class="score-fill" style="width: {{ (holonic_scores.get("ubuntu_alignment", 0) * 100)|round }}%"></div>
                    </div>
                    <span class="score-value">{{ (holonic_scores.get("ubuntu_alignment", 0) * 100)|round }}%</span>
                    <p class="dimension-description">
                        Evaluates adherence to Ubuntu principles of interconnectedness, mutual support,
                        and recognition that "I am because we are."
                    </p>
                </div>
                
                <div class="card dimension-card">
                    <h4>Reciprocity Health</h4>
                    <div class="score-bar">
                        <div class="score-fill" style="width: {{ (holonic_scores.get("reciprocity_health", 0) * 100)|round }}%"></div>
                    </div>
                    <span class="score-value">{{ (holonic_scores.get("reciprocity_health", 0) * 100)|round }}%</span>
                    <p class="dimension-description">
                        Assesses the balance of giving and receiving, tracking the health of reciprocal
                        relationships within the network.
                    </p>
                </div>
                
                <div class="card dimension-card">
                    <h4>Mutualism Capacity</h4>
                    <div class="score-bar">
                        <div class="score-fill" style="width: {{ (holonic_scores.get("mutualism_capacity", 0) * 100)|round }}%"></div>
                    </div>
                    <span class="score-value">{{ (holonic_scores.get("mutualism_capacity", 0) * 100)|round }}%</span>
                    <p class="dimension-description">
                        Measures the ability to form and maintain mutually beneficial relationships
                        where all parties gain value.
                    </p>
                </div>
                
                <div class="card dimension-card">
                    <h4>Regeneration Impact</h4>
                    <div class="score-bar">
                        <div class="score-fill" style="width: {{ (holonic_scores.get("regeneration_impact", 0) * 100)|round }}%"></div>
                    </div>
                    <span class="score-value">{{ (holonic_scores.get("regeneration_impact", 0) * 100)|round }}%</span>
                    <p class="dimension-description">
                        Tracks contributions to ecosystem healing and renewal, recognizing actions
                        that transform and regenerate the commons.
                    </p>
                </div>
            </div>
            {% else %}
            <div class="no-data-message">
                <p>Holonic evaluation scores are being calculated. Check back soon.</p>
            </div>
            {% endif %}
        </div>
        
        <!-- Stellar Integration -->
        <div class="protocol-section">
            <h2 class="section-title">Stellar Blockchain Integration</h2>
            <p class="section-description">
                UBEC tokens operate on the Stellar network, leveraging its fast, low-cost,
                and environmentally sustainable blockchain infrastructure.
            </p>
            
            <div class="integration-details">
                <div class="card detail-box">
                    <div class="detail-icon">🌐</div>
                    <h4>Network</h4>
                    <p>Stellar Mainnet (Public Network)</p>
                    <p class="detail-note">Production-ready since Oct 2015</p>
                </div>
                <div class="card detail-box">
                    <div class="detail-icon">⚡</div>
                    <h4>Transaction Speed</h4>
                    <p>3-5 seconds per confirmation</p>
                    <p class="detail-note">Near-instant settlement</p>
                </div>
                <div class="card detail-box">
                    <div class="detail-icon">💰</div>
                    <h4>Transaction Cost</h4>
                    <p>0.00001 XLM (~$0.000003)</p>
                    <p class="detail-note">Micropayment-friendly</p>
                </div>
                <div class="card detail-box">
                    <div class="detail-icon">🌱</div>
                    <h4>Energy Efficiency</h4>
                    <p>Carbon-neutral blockchain</p>
                    <p class="detail-note">Sustainable by design</p>
                </div>
            </div>
            
            <div class="stellar-benefits">
                <h3 class="section-title">Why Stellar?</h3>
                <div class="benefits-grid">
                    <div class="benefit-item">
                        <span class="benefit-icon">🔒</span>
                        <h5>Security</h5>
                        <p>Battle-tested consensus protocol with years of proven operation</p>
                    </div>
                    <div class="benefit-item">
                        <span class="benefit-icon">🌍</span>
                        <h5>Global Access</h5>
                        <p>Built for financial inclusion, supporting cross-border transactions</p>
                    </div>
                    <div class="benefit-item">
                        <span class="benefit-icon">🛠️</span>
                        <h5>Developer Friendly</h5>
                        <p>Rich APIs, comprehensive SDKs, and extensive documentation</p>
                    </div>
                    <div class="benefit-item">
                        <span class="benefit-icon">♻️</span>
                        <h5>Eco-Conscious</h5>
                        <p>Minimal energy footprint aligned with Ubuntu regenerative principles</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Technical Architecture -->
        <div class="protocol-section">
            <h2 class="section-title">Technical Architecture</h2>
            <p class="section-description">
                The UBEC Protocol implements a robust, scalable architecture designed for
                long-term sustainability and growth.
            </p>
            
            <div class="architecture-components">
                <div class="card component-card">
                    <h4>🏗️ Core Infrastructure</h4>
                    <ul>
                        <li><strong>Database:</strong> PostgreSQL with advanced indexing</li>
                        <li><strong>API Layer:</strong> FastAPI with async operations</li>
                        <li><strong>Frontend:</strong> Modern web stack with real-time updates</li>
                        <li><strong>Blockchain:</strong> Stellar network integration</li>
                    </ul>
                </div>
                
                <div class="card component-card">
                    <h4>🔄 Service Architecture</h4>
                    <ul>
                        <li><strong>Protocol Services:</strong> One per token element</li>
                        <li><strong>Holonic Evaluator:</strong> Ubuntu principle assessment</li>
                        <li><strong>Data Synchronizer:</strong> Blockchain-database sync</li>
                        <li><strong>Analytics Service:</strong> Network insights</li>
                    </ul>
                </div>
                
                <div class="card component-card">
                    <h4>🎯 Design Principles</h4>
                    <ul>
                        <li><strong>Async First:</strong> 100% non-blocking operations</li>
                        <li><strong>Modular Design:</strong> Independent, composable services</li>
                        <li><strong>Service Registry:</strong> Dynamic dependency management</li>
                        <li><strong>Single Source of Truth:</strong> Database as authority</li>
                    </ul>
                </div>
                
                <div class="card component-card">
                    <h4>🔐 Security & Performance</h4>
                    <ul>
                        <li><strong>Rate Limiting:</strong> Built-in API protection</li>
                        <li><strong>Caching:</strong> Intelligent response caching</li>
                        <li><strong>Error Handling:</strong> Comprehensive error management</li>
                        <li><strong>Monitoring:</strong> Real-time health checks</li>
                    </ul>
                </div>
            </div>
        </div>
        
        <!-- Call to Action -->
        <div class="protocol-cta">
            <h2 class="section-title">Explore the UBEC Network</h2>
            <p class="section-description">
                Dive deeper into the protocol, view live network data, or integrate with our API
            </p>
            <div class="cta-buttons">
                <a href="/dashboard" class="btn btn-primary">View Live Dashboard</a>
                <a href="/docs" class="btn btn-secondary">Read Documentation</a>
                <a href="/api/docs" class="btn btn-secondary">API Reference</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}

